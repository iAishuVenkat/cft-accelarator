# ============================================================
# ECS Fargate Service Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  # ----- ECS Cluster -----
  ECSCluster:
    Type: AWS::ECS::Cluster
    Properties:
      ClusterName: {{ resource_prefix }}-cluster
      ClusterSettings:
        - Name: containerInsights
          Value: enabled
      Tags:
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

  # ----- Task Execution Role -----
  TaskExecutionRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName: {{ resource_prefix }}-task-exec-role
      AssumeRolePolicyDocument:
        Version: '2012-10-17'
        Statement:
          - Effect: Allow
            Principal:
              Service: ecs-tasks.amazonaws.com
            Action: sts:AssumeRole
      ManagedPolicyArns:
        - arn:aws:iam::aws:policy/service-role/AmazonECSTaskExecutionRolePolicy

  # ----- Task Role -----
  TaskRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName: {{ resource_prefix }}-task-role
      AssumeRolePolicyDocument:
        Version: '2012-10-17'
        Statement:
          - Effect: Allow
            Principal:
              Service: ecs-tasks.amazonaws.com
            Action: sts:AssumeRole

  # ----- CloudWatch Log Group -----
  LogGroup:
    Type: AWS::Logs::LogGroup
    Properties:
      LogGroupName: /ecs/{{ resource_prefix }}
      RetentionInDays: 30

  # ----- Task Definition -----
  TaskDefinition:
    Type: AWS::ECS::TaskDefinition
    Properties:
      Family: {{ resource_prefix }}
      Cpu: '{{ component.cpu }}'
      Memory: '{{ component.memory }}'
      NetworkMode: awsvpc
      RequiresCompatibilities:
        - FARGATE
      ExecutionRoleArn: !GetAtt TaskExecutionRole.Arn
      TaskRoleArn: !GetAtt TaskRole.Arn
      ContainerDefinitions:
        - Name: {{ project }}-container
          Image: {{ component.image }}
          Essential: true
          PortMappings:
            - ContainerPort: {{ component.port }}
              Protocol: tcp
          LogConfiguration:
            LogDriver: awslogs
            Options:
              awslogs-group: !Ref LogGroup
              awslogs-region: {{ region }}
              awslogs-stream-prefix: ecs

  # ----- Security Group -----
  EcsServiceSecurityGroup:
    Type: AWS::EC2::SecurityGroup
    Properties:
      GroupDescription: Security group for {{ resource_prefix }} ECS service
      VpcId: !ImportValue {{ project }}-{{ environment }}-vpc-VpcId
      SecurityGroupIngress:
        - IpProtocol: tcp
          FromPort: {{ component.port }}
          ToPort: {{ component.port }}
          SourceSecurityGroupId: !Ref EcsALBSecurityGroup
      Tags:
        - Key: Name
          Value: {{ resource_prefix }}-sg

  EcsALBSecurityGroup:
    Type: AWS::EC2::SecurityGroup
    Properties:
      GroupDescription: Security group for {{ resource_prefix }} ALB
      VpcId: !ImportValue {{ project }}-{{ environment }}-vpc-VpcId
      SecurityGroupIngress:
        - IpProtocol: tcp
          FromPort: 80
          ToPort: 80
          CidrIp: 0.0.0.0/0
        - IpProtocol: tcp
          FromPort: 443
          ToPort: 443
          CidrIp: 0.0.0.0/0
      Tags:
        - Key: Name
          Value: {{ resource_prefix }}-alb-sg

  # ----- Application Load Balancer -----
  EcsLoadBalancer:
    Type: AWS::ElasticLoadBalancingV2::LoadBalancer
    Properties:
      Name: {{ resource_prefix }}-alb
      Scheme: internet-facing
      Type: application
      Subnets: !Split
        - ','
        - !ImportValue {{ project }}-{{ environment }}-vpc-PublicSubnets
      SecurityGroups:
        - !Ref EcsALBSecurityGroup

  EcsTargetGroup:
    Type: AWS::ElasticLoadBalancingV2::TargetGroup
    Properties:
      Name: {{ resource_prefix }}-tg
      Port: {{ component.port }}
      Protocol: HTTP
      TargetType: ip
      VpcId: !ImportValue {{ project }}-{{ environment }}-vpc-VpcId
      HealthCheckPath: {{ component.health_check_path }}
      HealthCheckIntervalSeconds: 30
      HealthyThresholdCount: 3
      UnhealthyThresholdCount: 3

  EcsListener:
    Type: AWS::ElasticLoadBalancingV2::Listener
    Properties:
      LoadBalancerArn: !Ref EcsLoadBalancer
      Port: 80
      Protocol: HTTP
      DefaultActions:
        - Type: forward
          TargetGroupArn: !Ref EcsTargetGroup

  # ----- ECS Service -----
  ECSService:
    Type: AWS::ECS::Service
    DependsOn: EcsListener
    Properties:
      ServiceName: {{ resource_prefix }}-service
      Cluster: !Ref ECSCluster
      TaskDefinition: !Ref TaskDefinition
      DesiredCount: {{ component.desired_count }}
      LaunchType: FARGATE
      NetworkConfiguration:
        AwsvpcConfiguration:
          AssignPublicIp: DISABLED
          Subnets: !Split
            - ','
            - !ImportValue {{ project }}-{{ environment }}-vpc-PrivateSubnets
          SecurityGroups:
            - !Ref EcsServiceSecurityGroup
      LoadBalancers:
        - ContainerName: {{ project }}-container
          ContainerPort: {{ component.port }}
          TargetGroupArn: !Ref EcsTargetGroup

  # ----- Auto Scaling -----
  AutoScalingTarget:
    Type: AWS::ApplicationAutoScaling::ScalableTarget
    Properties:
      MaxCapacity: {{ component.desired_count * 3 }}
      MinCapacity: {{ component.desired_count }}
      ResourceId: !Sub 'service/${ECSCluster}/${ECSService.Name}'
      ScalableDimension: ecs:service:DesiredCount
      ServiceNamespace: ecs
      RoleARN: !Sub 'arn:aws:iam::${AWS::AccountId}:role/aws-service-role/ecs.application-autoscaling.amazonaws.com/AWSServiceRoleForApplicationAutoScaling_ECSService'

  AutoScalingPolicy:
    Type: AWS::ApplicationAutoScaling::ScalingPolicy
    Properties:
      PolicyName: {{ resource_prefix }}-cpu-scaling
      PolicyType: TargetTrackingScaling
      ScalingTargetId: !Ref AutoScalingTarget
      TargetTrackingScalingPolicyConfiguration:
        PredefinedMetricSpecification:
          PredefinedMetricType: ECSServiceAverageCPUUtilization
        TargetValue: 70.0

Outputs:
  ClusterArn:
    Description: ECS Cluster ARN
    Value: !GetAtt ECSCluster.Arn
    Export:
      Name: {{ resource_prefix }}-ClusterArn

  ServiceUrl:
    Description: Load Balancer URL
    Value: !Sub 'http://${EcsLoadBalancer.DNSName}'
    Export:
      Name: {{ resource_prefix }}-ServiceUrl
