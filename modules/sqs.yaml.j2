# ============================================================
# SQS Queue Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  {% if component.enable_dlq %}
  DeadLetterQueue:
    Type: AWS::SQS::Queue
    Properties:
      QueueName: {{ resource_prefix }}-dlq{% if component.queue_type == 'fifo' %}.fifo{% endif %}
      {% if component.queue_type == 'fifo' %}
      FifoQueue: true
      {% endif %}
      MessageRetentionPeriod: 1209600
      SqsManagedSseEnabled: true
      Tags:
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}
  {% endif %}

  MainQueue:
    Type: AWS::SQS::Queue
    Properties:
      QueueName: {{ resource_prefix }}{% if component.queue_type == 'fifo' %}.fifo{% endif %}
      {% if component.queue_type == 'fifo' %}
      FifoQueue: true
      ContentBasedDeduplication: true
      {% endif %}
      VisibilityTimeout: {{ component.visibility_timeout }}
      MessageRetentionPeriod: {{ component.message_retention_days * 86400 }}
      SqsManagedSseEnabled: true
      {% if component.enable_dlq %}
      RedrivePolicy:
        deadLetterTargetArn: !GetAtt DeadLetterQueue.Arn
        maxReceiveCount: {{ component.max_receive_count }}
      {% endif %}
      Tags:
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

Outputs:
  QueueUrl:
    Description: SQS Queue URL
    Value: !Ref MainQueue
    Export:
      Name: {{ resource_prefix }}-QueueUrl

  QueueArn:
    Description: SQS Queue ARN
    Value: !GetAtt MainQueue.Arn
    Export:
      Name: {{ resource_prefix }}-QueueArn

  {% if component.enable_dlq %}
  DLQUrl:
    Description: Dead Letter Queue URL
    Value: !Ref DeadLetterQueue
    Export:
      Name: {{ resource_prefix }}-DLQUrl
  {% endif %}
