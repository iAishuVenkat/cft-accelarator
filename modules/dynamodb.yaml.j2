# ============================================================
# DynamoDB Table Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  DynamoDBTable:
    Type: AWS::DynamoDB::Table
    DeletionPolicy: Retain
    Properties:
      TableName: {{ component.table_name }}
      BillingMode: {{ component.billing_mode }}
      AttributeDefinitions:
        - AttributeName: {{ component.partition_key }}
          AttributeType: {{ component.partition_key_type }}
        {% if component.sort_key %}
        - AttributeName: {{ component.sort_key }}
          AttributeType: {{ component.sort_key_type }}
        {% endif %}
      KeySchema:
        - AttributeName: {{ component.partition_key }}
          KeyType: HASH
        {% if component.sort_key %}
        - AttributeName: {{ component.sort_key }}
          KeyType: RANGE
        {% endif %}
      PointInTimeRecoverySpecification:
        PointInTimeRecoveryEnabled: {{ component.enable_point_in_time_recovery | lower }}
      SSESpecification:
        SSEEnabled: true
      Tags:
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

Outputs:
  TableName:
    Description: DynamoDB Table Name
    Value: !Ref DynamoDBTable
    Export:
      Name: {{ resource_prefix }}-TableName

  TableArn:
    Description: DynamoDB Table ARN
    Value: !GetAtt DynamoDBTable.Arn
    Export:
      Name: {{ resource_prefix }}-TableArn
