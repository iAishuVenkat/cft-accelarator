# ============================================================
# VPC Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  # ----- VPC -----
  VPC:
    Type: AWS::EC2::VPC
    Properties:
      CidrBlock: {{ component.cidr }}
      EnableDnsHostnames: true
      EnableDnsSupport: true
      Tags:
        - Key: Name
          Value: {{ resource_prefix }}-vpc
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

  # ----- Internet Gateway -----
  InternetGateway:
    Type: AWS::EC2::InternetGateway
    Properties:
      Tags:
        - Key: Name
          Value: {{ resource_prefix }}-igw

  InternetGatewayAttachment:
    Type: AWS::EC2::VPCGatewayAttachment
    Properties:
      InternetGatewayId: !Ref InternetGateway
      VpcId: !Ref VPC

  # ----- Public Subnets -----
  {% for az in range(component.availability_zones) %}
  PublicSubnet{{ az + 1 }}:
    Type: AWS::EC2::Subnet
    Properties:
      VpcId: !Ref VPC
      AvailabilityZone: !Select [ {{ az }}, !GetAZs '' ]
      CidrBlock: !Select [ {{ az }}, !Cidr [ !GetAtt VPC.CidrBlock, {{ component.availability_zones * 2 }}, 8 ] ]
      MapPublicIpOnLaunch: true
      Tags:
        - Key: Name
          Value: {{ resource_prefix }}-public-{{ az + 1 }}

  {% endfor %}

  # ----- Private Subnets -----
  {% for az in range(component.availability_zones) %}
  PrivateSubnet{{ az + 1 }}:
    Type: AWS::EC2::Subnet
    Properties:
      VpcId: !Ref VPC
      AvailabilityZone: !Select [ {{ az }}, !GetAZs '' ]
      CidrBlock: !Select [ {{ az + component.availability_zones }}, !Cidr [ !GetAtt VPC.CidrBlock, {{ component.availability_zones * 2 }}, 8 ] ]
      MapPublicIpOnLaunch: false
      Tags:
        - Key: Name
          Value: {{ resource_prefix }}-private-{{ az + 1 }}

  {% endfor %}

  # ----- Public Route Table -----
  PublicRouteTable:
    Type: AWS::EC2::RouteTable
    Properties:
      VpcId: !Ref VPC
      Tags:
        - Key: Name
          Value: {{ resource_prefix }}-public-rt

  PublicRoute:
    Type: AWS::EC2::Route
    DependsOn: InternetGatewayAttachment
    Properties:
      RouteTableId: !Ref PublicRouteTable
      DestinationCidrBlock: 0.0.0.0/0
      GatewayId: !Ref InternetGateway

  {% for az in range(component.availability_zones) %}
  PublicSubnet{{ az + 1 }}RouteTableAssociation:
    Type: AWS::EC2::SubnetRouteTableAssociation
    Properties:
      RouteTableId: !Ref PublicRouteTable
      SubnetId: !Ref PublicSubnet{{ az + 1 }}

  {% endfor %}

  {% if component.enable_nat_gateway %}
  # ----- NAT Gateway -----
  NatGatewayEIP:
    Type: AWS::EC2::EIP
    DependsOn: InternetGatewayAttachment
    Properties:
      Domain: vpc

  NatGateway:
    Type: AWS::EC2::NatGateway
    Properties:
      AllocationId: !GetAtt NatGatewayEIP.AllocationId
      SubnetId: !Ref PublicSubnet1
      Tags:
        - Key: Name
          Value: {{ resource_prefix }}-nat

  # ----- Private Route Table -----
  PrivateRouteTable:
    Type: AWS::EC2::RouteTable
    Properties:
      VpcId: !Ref VPC
      Tags:
        - Key: Name
          Value: {{ resource_prefix }}-private-rt

  PrivateRoute:
    Type: AWS::EC2::Route
    Properties:
      RouteTableId: !Ref PrivateRouteTable
      DestinationCidrBlock: 0.0.0.0/0
      NatGatewayId: !Ref NatGateway

  {% for az in range(component.availability_zones) %}
  PrivateSubnet{{ az + 1 }}RouteTableAssociation:
    Type: AWS::EC2::SubnetRouteTableAssociation
    Properties:
      RouteTableId: !Ref PrivateRouteTable
      SubnetId: !Ref PrivateSubnet{{ az + 1 }}

  {% endfor %}
  {% endif %}

Outputs:
  VpcId:
    Description: VPC ID
    Value: !Ref VPC
    Export:
      Name: {{ resource_prefix }}-VpcId

  PublicSubnets:
    Description: Public subnet IDs
    Value: !Join
      - ','
      - {% for az in range(component.availability_zones) %}
        - !Ref PublicSubnet{{ az + 1 }}
        {% endfor %}
    Export:
      Name: {{ resource_prefix }}-PublicSubnets

  PrivateSubnets:
    Description: Private subnet IDs
    Value: !Join
      - ','
      - {% for az in range(component.availability_zones) %}
        - !Ref PrivateSubnet{{ az + 1 }}
        {% endfor %}
    Export:
      Name: {{ resource_prefix }}-PrivateSubnets
