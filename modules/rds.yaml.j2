# ============================================================
# RDS Database Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  # ----- DB Subnet Group -----
  DBSubnetGroup:
    Type: AWS::RDS::DBSubnetGroup
    Properties:
      DBSubnetGroupDescription: Subnet group for {{ resource_prefix }}
      SubnetIds: !Split
        - ','
        - !ImportValue {{ project }}-{{ environment }}-vpc-PrivateSubnets
      Tags:
        - Key: Name
          Value: {{ resource_prefix }}-subnet-group
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

  # ----- Security Group -----
  DBSecurityGroup:
    Type: AWS::EC2::SecurityGroup
    Properties:
      GroupDescription: Security group for {{ resource_prefix }} RDS
      VpcId: !ImportValue {{ project }}-{{ environment }}-vpc-VpcId
      SecurityGroupIngress:
        - IpProtocol: tcp
          {% if component.engine == 'postgres' %}
          FromPort: 5432
          ToPort: 5432
          {% else %}
          FromPort: 3306
          ToPort: 3306
          {% endif %}
          CidrIp: 10.0.0.0/16
      Tags:
        - Key: Name
          Value: {{ resource_prefix }}-db-sg

  # ----- Secrets Manager Secret (for DB password) -----
  DBSecret:
    Type: AWS::SecretsManager::Secret
    Properties:
      Name: {{ resource_prefix }}-db-credentials
      Description: Database credentials for {{ resource_prefix }}
      GenerateSecretString:
        SecretStringTemplate: '{"username": "dbadmin"}'
        GenerateStringKey: password
        PasswordLength: 32
        ExcludeCharacters: '"@/\'

  # ----- RDS Instance -----
  DBInstance:
    Type: AWS::RDS::DBInstance
    DeletionPolicy: Snapshot
    Properties:
      DBInstanceIdentifier: {{ resource_prefix }}
      DBInstanceClass: {{ component.instance_class }}
      Engine: {{ component.engine }}
      EngineVersion: '{{ component.engine_version }}'
      AllocatedStorage: {{ component.allocated_storage }}
      StorageType: gp3
      StorageEncrypted: true
      MasterUsername: !Sub '{{"{{"}}resolve:secretsmanager:${DBSecret}:SecretString:username{{"}}"}}'
      MasterUserPassword: !Sub '{{"{{"}}resolve:secretsmanager:${DBSecret}:SecretString:password{{"}}"}}'
      DBSubnetGroupName: !Ref DBSubnetGroup
      VPCSecurityGroups:
        - !Ref DBSecurityGroup
      MultiAZ: {{ component.multi_az | lower }}
      BackupRetentionPeriod: {{ component.backup_retention_days }}
      PreferredBackupWindow: '03:00-04:00'
      PreferredMaintenanceWindow: 'sun:04:00-sun:05:00'
      DeletionProtection: {% if environment == 'prod' %}true{% else %}false{% endif %}

      CopyTagsToSnapshot: true
      Tags:
        - Key: Name
          Value: {{ resource_prefix }}
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

Outputs:
  DBEndpoint:
    Description: Database endpoint address
    Value: !GetAtt DBInstance.Endpoint.Address
    Export:
      Name: {{ resource_prefix }}-DBEndpoint

  DBPort:
    Description: Database port
    Value: !GetAtt DBInstance.Endpoint.Port
    Export:
      Name: {{ resource_prefix }}-DBPort

  DBSecretArn:
    Description: Secret ARN for DB credentials
    Value: !Ref DBSecret
    Export:
      Name: {{ resource_prefix }}-DBSecretArn
