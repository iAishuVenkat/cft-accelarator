# ============================================================
# Lambda Function Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  # ----- Lambda Execution Role -----
  LambdaExecutionRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName: {{ resource_prefix }}-lambda-role
      AssumeRolePolicyDocument:
        Version: '2012-10-17'
        Statement:
          - Effect: Allow
            Principal:
              Service: lambda.amazonaws.com
            Action: sts:AssumeRole
      ManagedPolicyArns:
        - arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole
        - arn:aws:iam::aws:policy/service-role/AWSLambdaVPCAccessExecutionRole
      Tags:
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

  # ----- CloudWatch Log Group -----
  LambdaLogGroup:
    Type: AWS::Logs::LogGroup
    Properties:
      LogGroupName: /aws/lambda/{{ resource_prefix }}
      RetentionInDays: 14

  # ----- Lambda Function -----
  LambdaFunction:
    Type: AWS::Lambda::Function
    DependsOn: LambdaLogGroup
    Properties:
      FunctionName: {{ resource_prefix }}
      Runtime: {{ component.runtime }}
      Handler: {{ component.handler }}
      MemorySize: {{ component.memory_size }}
      Timeout: {{ component.timeout }}
      Role: !GetAtt LambdaExecutionRole.Arn
      Code:
        ZipFile: |
          # Placeholder - replace with your deployment package
          def handler(event, context):
              return {
                  'statusCode': 200,
                  'body': 'Hello from {{ resource_prefix }}'
              }
      {% if component.environment_vars %}
      Environment:
        Variables:
          ENVIRONMENT: {{ environment }}
          {% for key, value in component.environment_vars.items() %}
          {{ key }}: {{ value }}
          {% endfor %}
      {% else %}
      Environment:
        Variables:
          ENVIRONMENT: {{ environment }}
      {% endif %}
      Tags:
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

Outputs:
  LambdaFunctionArn:
    Description: Lambda Function ARN
    Value: !GetAtt LambdaFunction.Arn
    Export:
      Name: {{ resource_prefix }}-LambdaArn

  LambdaFunctionName:
    Description: Lambda Function Name
    Value: !Ref LambdaFunction
    Export:
      Name: {{ resource_prefix }}-LambdaName
