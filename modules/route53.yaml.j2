# ============================================================
# Route 53 Hosted Zone Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  HostedZone:
    Type: AWS::Route53::HostedZone
    Properties:
      Name: {{ component.domain_name }}
      {% if component.private_zone %}
      VPCs:
        - VPCId: !ImportValue {{ project }}-{{ environment }}-vpc-VpcId
          VPCRegion: {{ region }}
      {% endif %}
      HostedZoneConfig:
        Comment: Hosted zone for {{ resource_prefix }}
      HostedZoneTags:
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

Outputs:
  HostedZoneId:
    Description: Hosted Zone ID
    Value: !Ref HostedZone
    Export:
      Name: {{ resource_prefix }}-HostedZoneId

  NameServers:
    Description: Name Servers
    Value: !Join
      - ','
      - !GetAtt HostedZone.NameServers
    Export:
      Name: {{ resource_prefix }}-NameServers
