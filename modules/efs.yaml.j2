# ============================================================
# EFS File System Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  FileSystem:
    Type: AWS::EFS::FileSystem
    Properties:
      PerformanceMode: {{ component.performance_mode }}
      ThroughputMode: {{ component.throughput_mode }}
      Encrypted: {{ component.encrypted | lower }}
      FileSystemTags:
        - Key: Name
          Value: {{ resource_prefix }}
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

  MountTargetSecurityGroup:
    Type: AWS::EC2::SecurityGroup
    Properties:
      GroupDescription: Security group for {{ resource_prefix }} EFS mount targets
      VpcId: !ImportValue {{ project }}-{{ environment }}-vpc-VpcId
      SecurityGroupIngress:
        - IpProtocol: tcp
          FromPort: 2049
          ToPort: 2049
          CidrIp: 10.0.0.0/16
      Tags:
        - Key: Name
          Value: {{ resource_prefix }}-efs-sg

  MountTarget1:
    Type: AWS::EFS::MountTarget
    Properties:
      FileSystemId: !Ref FileSystem
      SubnetId: !Select
        - 0
        - !Split
          - ','
          - !ImportValue {{ project }}-{{ environment }}-vpc-PrivateSubnets
      SecurityGroups:
        - !Ref MountTargetSecurityGroup

  MountTarget2:
    Type: AWS::EFS::MountTarget
    Properties:
      FileSystemId: !Ref FileSystem
      SubnetId: !Select
        - 1
        - !Split
          - ','
          - !ImportValue {{ project }}-{{ environment }}-vpc-PrivateSubnets
      SecurityGroups:
        - !Ref MountTargetSecurityGroup

Outputs:
  FileSystemId:
    Description: EFS File System ID
    Value: !Ref FileSystem
    Export:
      Name: {{ resource_prefix }}-FileSystemId

  FileSystemArn:
    Description: EFS File System ARN
    Value: !GetAtt FileSystem.Arn
    Export:
      Name: {{ resource_prefix }}-FileSystemArn
