# ============================================================
# EC2 Instance Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  EC2Role:
    Type: AWS::IAM::Role
    Properties:
      RoleName: {{ resource_prefix }}-ec2-role
      AssumeRolePolicyDocument:
        Version: '2012-10-17'
        Statement:
          - Effect: Allow
            Principal:
              Service: ec2.amazonaws.com
            Action: sts:AssumeRole
      ManagedPolicyArns:
        - arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore

  EC2InstanceProfile:
    Type: AWS::IAM::InstanceProfile
    Properties:
      Roles:
        - !Ref EC2Role

  EC2SecurityGroup:
    Type: AWS::EC2::SecurityGroup
    Properties:
      GroupDescription: Security group for {{ resource_prefix }}
      VpcId: !ImportValue {{ project }}-{{ environment }}-vpc-VpcId
      SecurityGroupIngress:
        - IpProtocol: tcp
          FromPort: 443
          ToPort: 443
          CidrIp: 0.0.0.0/0
      Tags:
        - Key: Name
          Value: {{ resource_prefix }}-sg
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

  EC2Instance:
    Type: AWS::EC2::Instance
    Properties:
      InstanceType: {{ component.instance_type }}
      {% if component.ami_id %}
      ImageId: {{ component.ami_id }}
      {% else %}
      ImageId: !Sub '{{"{{"}}resolve:ssm:/aws/service/ami-amazon-linux-latest/al2023-ami-kernel-6.1-x86_64{{"}}"}}'
      {% endif %}
      IamInstanceProfile: !Ref EC2InstanceProfile
      SubnetId: !Select
        - 0
        - !Split
          - ','
          - !ImportValue {{ project }}-{{ environment }}-vpc-{% if component.assign_public_ip %}PublicSubnets{% else %}PrivateSubnets{% endif %}
      SecurityGroupIds:
        - !Ref EC2SecurityGroup
      {% if component.key_pair %}
      KeyName: {{ component.key_pair }}
      {% endif %}
      BlockDeviceMappings:
        - DeviceName: /dev/xvda
          Ebs:
            VolumeSize: {{ component.volume_size }}
            VolumeType: gp3
            Encrypted: true
      Tags:
        - Key: Name
          Value: {{ resource_prefix }}
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

Outputs:
  InstanceId:
    Description: EC2 Instance ID
    Value: !Ref EC2Instance
    Export:
      Name: {{ resource_prefix }}-InstanceId

  PrivateIp:
    Description: Private IP Address
    Value: !GetAtt EC2Instance.PrivateIp
    Export:
      Name: {{ resource_prefix }}-PrivateIp
