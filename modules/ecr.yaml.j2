# ============================================================
# ECR Repository Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  Repository:
    Type: AWS::ECR::Repository
    Properties:
      RepositoryName: {{ component.repository_name }}
      ImageTagMutability: {{ component.image_tag_mutability }}
      ImageScanningConfiguration:
        ScanOnPush: {{ component.scan_on_push | lower }}
      EncryptionConfiguration:
        EncryptionType: AES256
      LifecyclePolicy:
        LifecyclePolicyText: |
          {
            "rules": [
              {
                "rulePriority": 1,
                "description": "Keep last {{ component.lifecycle_max_images }} images",
                "selection": {
                  "tagStatus": "any",
                  "countType": "imageCountMoreThan",
                  "countNumber": {{ component.lifecycle_max_images }}
                },
                "action": {
                  "type": "expire"
                }
              }
            ]
          }
      Tags:
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

Outputs:
  RepositoryUri:
    Description: ECR Repository URI
    Value: !GetAtt Repository.RepositoryUri
    Export:
      Name: {{ resource_prefix }}-RepositoryUri

  RepositoryArn:
    Description: ECR Repository ARN
    Value: !GetAtt Repository.Arn
    Export:
      Name: {{ resource_prefix }}-RepositoryArn
