# ============================================================
# Network Load Balancer Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  NLB:
    Type: AWS::ElasticLoadBalancingV2::LoadBalancer
    Properties:
      Name: {{ resource_prefix }}-nlb
      Scheme: {% if component.internal %}internal{% else %}internet-facing{% endif %}
      Type: network
      Subnets: !Split
        - ','
        - {% if component.internal %}!ImportValue {{ project }}-{{ environment }}-vpc-PrivateSubnets{% else %}!ImportValue {{ project }}-{{ environment }}-vpc-PublicSubnets{% endif %}
      LoadBalancerAttributes:
        - Key: load_balancing.cross_zone.enabled
          Value: '{{ component.cross_zone | lower }}'
      Tags:
        - Key: Name
          Value: {{ resource_prefix }}-nlb
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

  NLBTargetGroup:
    Type: AWS::ElasticLoadBalancingV2::TargetGroup
    Properties:
      Name: {{ resource_prefix }}-tg
      Port: 80
      Protocol: TCP
      TargetType: ip
      VpcId: !ImportValue {{ project }}-{{ environment }}-vpc-VpcId
      HealthCheckProtocol: TCP
      HealthCheckIntervalSeconds: 30
      HealthyThresholdCount: 3
      UnhealthyThresholdCount: 3

  NLBListener:
    Type: AWS::ElasticLoadBalancingV2::Listener
    Properties:
      LoadBalancerArn: !Ref NLB
      Port: 80
      Protocol: TCP
      DefaultActions:
        - Type: forward
          TargetGroupArn: !Ref NLBTargetGroup

Outputs:
  NLBArn:
    Description: NLB ARN
    Value: !Ref NLB
    Export:
      Name: {{ resource_prefix }}-NLBArn

  NLBDns:
    Description: NLB DNS Name
    Value: !GetAtt NLB.DNSName
    Export:
      Name: {{ resource_prefix }}-NLBDns
