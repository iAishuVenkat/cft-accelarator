# ============================================================
# EventBridge Event Bus Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  EventBus:
    Type: AWS::Events::EventBus
    Properties:
      Name: {{ component.bus_name }}
      Tags:
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

  EventBusPolicy:
    Type: AWS::Events::EventBusPolicy
    Properties:
      EventBusName: !Ref EventBus
      StatementId: AllowAccountAccess
      Statement:
        Effect: Allow
        Principal:
          AWS: !Sub 'arn:aws:iam::${AWS::AccountId}:root'
        Action: events:PutEvents
        Resource: !GetAtt EventBus.Arn

  DeadLetterQueue:
    Type: AWS::SQS::Queue
    Properties:
      QueueName: {{ resource_prefix }}-events-dlq
      MessageRetentionPeriod: 1209600
      SqsManagedSseEnabled: true

Outputs:
  EventBusArn:
    Description: Event Bus ARN
    Value: !GetAtt EventBus.Arn
    Export:
      Name: {{ resource_prefix }}-EventBusArn

  EventBusName:
    Description: Event Bus Name
    Value: !Ref EventBus
    Export:
      Name: {{ resource_prefix }}-EventBusName
