# ============================================================
# Aurora Cluster Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  DBSubnetGroup:
    Type: AWS::RDS::DBSubnetGroup
    Properties:
      DBSubnetGroupDescription: Subnet group for {{ resource_prefix }}
      SubnetIds: !Split
        - ','
        - !ImportValue {{ project }}-{{ environment }}-vpc-PrivateSubnets

  DBSecurityGroup:
    Type: AWS::EC2::SecurityGroup
    Properties:
      GroupDescription: Security group for {{ resource_prefix }} Aurora
      VpcId: !ImportValue {{ project }}-{{ environment }}-vpc-VpcId
      SecurityGroupIngress:
        - IpProtocol: tcp
          FromPort: 5432
          ToPort: 5432
          CidrIp: 10.0.0.0/16
      Tags:
        - Key: Name
          Value: {{ resource_prefix }}-db-sg

  DBSecret:
    Type: AWS::SecretsManager::Secret
    Properties:
      Name: {{ resource_prefix }}-credentials
      GenerateSecretString:
        SecretStringTemplate: '{"username": "dbadmin"}'
        GenerateStringKey: password
        PasswordLength: 32
        ExcludeCharacters: '"@/\'

  AuroraCluster:
    Type: AWS::RDS::DBCluster
    DeletionPolicy: Snapshot
    Properties:
      DBClusterIdentifier: {{ resource_prefix }}
      Engine: {{ component.engine }}
      EngineVersion: '{{ component.engine_version }}'
      MasterUsername: !Sub '{{"{{"}}resolve:secretsmanager:${DBSecret}:SecretString:username{{"}}"}}'
      MasterUserPassword: !Sub '{{"{{"}}resolve:secretsmanager:${DBSecret}:SecretString:password{{"}}"}}'
      DBSubnetGroupName: !Ref DBSubnetGroup
      VpcSecurityGroupIds:
        - !Ref DBSecurityGroup
      StorageEncrypted: true
      BackupRetentionPeriod: 7
      DeletionProtection: {% if environment == 'prod' %}true{% else %}false{% endif %}
      {% if component.serverless %}
      ServerlessV2ScalingConfiguration:
        MinCapacity: {{ component.min_capacity }}
        MaxCapacity: {{ component.max_capacity }}
      {% endif %}
      Tags:
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

  AuroraInstance1:
    Type: AWS::RDS::DBInstance
    Properties:
      DBClusterIdentifier: !Ref AuroraCluster
      DBInstanceIdentifier: {{ resource_prefix }}-instance-1
      Engine: {{ component.engine }}
      {% if component.serverless %}
      DBInstanceClass: db.serverless
      {% else %}
      DBInstanceClass: db.r6g.large
      {% endif %}

  AuroraInstance2:
    Type: AWS::RDS::DBInstance
    Properties:
      DBClusterIdentifier: !Ref AuroraCluster
      DBInstanceIdentifier: {{ resource_prefix }}-instance-2
      Engine: {{ component.engine }}
      {% if component.serverless %}
      DBInstanceClass: db.serverless
      {% else %}
      DBInstanceClass: db.r6g.large
      {% endif %}

Outputs:
  ClusterEndpoint:
    Description: Aurora Cluster Endpoint
    Value: !GetAtt AuroraCluster.Endpoint.Address
    Export:
      Name: {{ resource_prefix }}-ClusterEndpoint

  ReaderEndpoint:
    Description: Aurora Reader Endpoint
    Value: !GetAtt AuroraCluster.ReadEndpoint.Address
    Export:
      Name: {{ resource_prefix }}-ReaderEndpoint

  SecretArn:
    Description: DB Credentials Secret ARN
    Value: !Ref DBSecret
    Export:
      Name: {{ resource_prefix }}-SecretArn
