# ============================================================
# ECS Cluster Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  ECSCluster:
    Type: AWS::ECS::Cluster
    Properties:
      ClusterName: {{ resource_prefix }}-cluster
      ClusterSettings:
        - Name: containerInsights
          Value: {% if component.enable_container_insights %}enabled{% else %}disabled{% endif %}
      CapacityProviders:
        - FARGATE
        - FARGATE_SPOT
      DefaultCapacityProviderStrategy:
        - CapacityProvider: FARGATE
          Weight: 1
        - CapacityProvider: FARGATE_SPOT
          Weight: 1
      Tags:
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

Outputs:
  ClusterArn:
    Description: ECS Cluster ARN
    Value: !GetAtt ECSCluster.Arn
    Export:
      Name: {{ resource_prefix }}-ClusterArn

  ClusterName:
    Description: ECS Cluster Name
    Value: !Ref ECSCluster
    Export:
      Name: {{ resource_prefix }}-ClusterName
