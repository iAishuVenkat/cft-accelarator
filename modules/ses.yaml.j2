# ============================================================
# SES Email Service Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  EmailIdentity:
    Type: AWS::SES::EmailIdentity
    Properties:
      EmailIdentity: {{ component.domain }}

  ConfigurationSet:
    Type: AWS::SES::ConfigurationSet
    Properties:
      Name: {{ resource_prefix }}-config
      ReputationOptions:
        ReputationMetricsEnabled: true
      SendingOptions:
        SendingEnabled: true
      SuppressionOptions:
        SuppressedReasons:
          - BOUNCE
          - COMPLAINT

Outputs:
  EmailIdentityName:
    Description: SES Email Identity
    Value: {{ component.domain }}
    Export:
      Name: {{ resource_prefix }}-EmailIdentity

  ConfigurationSetName:
    Description: SES Configuration Set
    Value: !Ref ConfigurationSet
    Export:
      Name: {{ resource_prefix }}-ConfigSet
