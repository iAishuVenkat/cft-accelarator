# ============================================================
# Cognito User Pool Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  UserPool:
    Type: AWS::Cognito::UserPool
    Properties:
      UserPoolName: {{ resource_prefix }}-{{ component.pool_name }}
      AutoVerifiedAttributes:
        - {{ component.auto_verified_attributes }}
      MfaConfiguration: {{ component.mfa_configuration }}
      Policies:
        PasswordPolicy:
          MinimumLength: {{ component.password_min_length }}
          RequireLowercase: true
          RequireUppercase: true
          RequireNumbers: true
          RequireSymbols: true
      Schema:
        - Name: email
          AttributeDataType: String
          Required: true
          Mutable: true
      AccountRecoverySetting:
        RecoveryMechanisms:
          - Name: verified_email
            Priority: 1
      UserPoolAddOns:
        AdvancedSecurityMode: ENFORCED
      Tags:
        {% for key, value in tags.items() %}
        {{ key }}: {{ value }}
        {% endfor %}

  UserPoolClient:
    Type: AWS::Cognito::UserPoolClient
    Properties:
      ClientName: {{ resource_prefix }}-app-client
      UserPoolId: !Ref UserPool
      GenerateSecret: false
      ExplicitAuthFlows:
        - ALLOW_USER_SRP_AUTH
        - ALLOW_REFRESH_TOKEN_AUTH
      PreventUserExistenceErrors: ENABLED
      AccessTokenValidity: 1
      IdTokenValidity: 1
      RefreshTokenValidity: 30
      TokenValidityUnits:
        AccessToken: hours
        IdToken: hours
        RefreshToken: days

Outputs:
  UserPoolId:
    Description: Cognito User Pool ID
    Value: !Ref UserPool
    Export:
      Name: {{ resource_prefix }}-UserPoolId

  UserPoolArn:
    Description: Cognito User Pool ARN
    Value: !GetAtt UserPool.Arn
    Export:
      Name: {{ resource_prefix }}-UserPoolArn

  AppClientId:
    Description: App Client ID
    Value: !Ref UserPoolClient
    Export:
      Name: {{ resource_prefix }}-AppClientId
