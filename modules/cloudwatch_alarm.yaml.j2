# ============================================================
# CloudWatch Alarm Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  AlarmTopic:
    Type: AWS::SNS::Topic
    Properties:
      TopicName: {{ resource_prefix }}-alarm-topic
      Tags:
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

  Alarm:
    Type: AWS::CloudWatch::Alarm
    Properties:
      AlarmName: {{ component.alarm_name }}
      AlarmDescription: Alarm for {{ component.metric_name }} in {{ component.namespace }}
      MetricName: {{ component.metric_name }}
      Namespace: {{ component.namespace }}
      Statistic: Average
      Period: {{ component.period }}
      EvaluationPeriods: {{ component.evaluation_periods }}
      Threshold: {{ component.threshold }}
      ComparisonOperator: {{ component.comparison_operator }}
      AlarmActions:
        - !Ref AlarmTopic
      OKActions:
        - !Ref AlarmTopic
      TreatMissingData: notBreaching

Outputs:
  AlarmArn:
    Description: Alarm ARN
    Value: !GetAtt Alarm.Arn
    Export:
      Name: {{ resource_prefix }}-AlarmArn

  AlarmTopicArn:
    Description: Alarm SNS Topic ARN
    Value: !Ref AlarmTopic
    Export:
      Name: {{ resource_prefix }}-AlarmTopicArn
