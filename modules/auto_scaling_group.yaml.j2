# ============================================================
# Auto Scaling Group Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  ASGRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName: {{ resource_prefix }}-asg-role
      AssumeRolePolicyDocument:
        Version: '2012-10-17'
        Statement:
          - Effect: Allow
            Principal:
              Service: ec2.amazonaws.com
            Action: sts:AssumeRole
      ManagedPolicyArns:
        - arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore

  ASGInstanceProfile:
    Type: AWS::IAM::InstanceProfile
    Properties:
      Roles:
        - !Ref ASGRole

  ASGSecurityGroup:
    Type: AWS::EC2::SecurityGroup
    Properties:
      GroupDescription: Security group for {{ resource_prefix }} ASG
      VpcId: !ImportValue {{ project }}-{{ environment }}-vpc-VpcId
      Tags:
        - Key: Name
          Value: {{ resource_prefix }}-asg-sg

  LaunchTemplate:
    Type: AWS::EC2::LaunchTemplate
    Properties:
      LaunchTemplateName: {{ resource_prefix }}-lt
      LaunchTemplateData:
        InstanceType: {{ component.instance_type }}
        ImageId: !Sub '{{"{{"}}resolve:ssm:/aws/service/ami-amazon-linux-latest/al2023-ami-kernel-6.1-x86_64{{"}}"}}'
        IamInstanceProfile:
          Arn: !GetAtt ASGInstanceProfile.Arn
        SecurityGroupIds:
          - !Ref ASGSecurityGroup
        BlockDeviceMappings:
          - DeviceName: /dev/xvda
            Ebs:
              VolumeSize: 30
              VolumeType: gp3
              Encrypted: true
        TagSpecifications:
          - ResourceType: instance
            Tags:
              - Key: Name
                Value: {{ resource_prefix }}
              {% for key, value in tags.items() %}
              - Key: {{ key }}
                Value: {{ value }}
              {% endfor %}

  AutoScalingGroup:
    Type: AWS::AutoScaling::AutoScalingGroup
    Properties:
      AutoScalingGroupName: {{ resource_prefix }}-asg
      LaunchTemplate:
        LaunchTemplateId: !Ref LaunchTemplate
        Version: !GetAtt LaunchTemplate.LatestVersionNumber
      MinSize: {{ component.min_size }}
      MaxSize: {{ component.max_size }}
      DesiredCapacity: {{ component.desired_capacity }}
      HealthCheckType: {{ component.health_check_type }}
      HealthCheckGracePeriod: 300
      VPCZoneIdentifier: !Split
        - ','
        - !ImportValue {{ project }}-{{ environment }}-vpc-PrivateSubnets
      Tags:
        - Key: Name
          Value: {{ resource_prefix }}
          PropagateAtLaunch: true

  ScalingPolicy:
    Type: AWS::AutoScaling::ScalingPolicy
    Properties:
      AutoScalingGroupName: !Ref AutoScalingGroup
      PolicyType: TargetTrackingScaling
      TargetTrackingConfiguration:
        PredefinedMetricSpecification:
          PredefinedMetricType: ASGAverageCPUUtilization
        TargetValue: 70.0

Outputs:
  ASGName:
    Description: Auto Scaling Group Name
    Value: !Ref AutoScalingGroup
    Export:
      Name: {{ resource_prefix }}-ASGName
