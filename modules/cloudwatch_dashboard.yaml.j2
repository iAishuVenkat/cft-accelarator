# ============================================================
# CloudWatch Dashboard Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  Dashboard:
    Type: AWS::CloudWatch::Dashboard
    Properties:
      DashboardName: {{ component.dashboard_name }}
      DashboardBody: !Sub |
        {
          "widgets": [
            {
              "type": "text",
              "x": 0,
              "y": 0,
              "width": 24,
              "height": 2,
              "properties": {
                "markdown": "# {{ project }} - {{ environment }} Dashboard\nGenerated by CFT Accelerator"
              }
            },
            {
              "type": "metric",
              "x": 0,
              "y": 2,
              "width": 12,
              "height": 6,
              "properties": {
                "metrics": [
                  ["AWS/ECS", "CPUUtilization", "ClusterName", "{{ project }}-{{ environment }}"]
                ],
                "period": 300,
                "stat": "Average",
                "region": "{{ region }}",
                "title": "ECS CPU Utilization"
              }
            },
            {
              "type": "metric",
              "x": 12,
              "y": 2,
              "width": 12,
              "height": 6,
              "properties": {
                "metrics": [
                  ["AWS/ECS", "MemoryUtilization", "ClusterName", "{{ project }}-{{ environment }}"]
                ],
                "period": 300,
                "stat": "Average",
                "region": "{{ region }}",
                "title": "ECS Memory Utilization"
              }
            }
          ]
        }

Outputs:
  DashboardName:
    Description: Dashboard Name
    Value: {{ component.dashboard_name }}
    Export:
      Name: {{ resource_prefix }}-DashboardName
