# ============================================================
# Glue ETL Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  GlueDatabase:
    Type: AWS::Glue::Database
    Properties:
      CatalogId: !Ref AWS::AccountId
      DatabaseInput:
        Name: {{ component.database_name }}
        Description: Glue catalog database for {{ resource_prefix }}

  GlueRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName: {{ resource_prefix }}-glue-role
      AssumeRolePolicyDocument:
        Version: '2012-10-17'
        Statement:
          - Effect: Allow
            Principal:
              Service: glue.amazonaws.com
            Action: sts:AssumeRole
      ManagedPolicyArns:
        - arn:aws:iam::aws:policy/service-role/AWSGlueServiceRole
      Policies:
        - PolicyName: GlueS3Access
          PolicyDocument:
            Version: '2012-10-17'
            Statement:
              - Effect: Allow
                Action:
                  - s3:GetObject
                  - s3:PutObject
                  - s3:ListBucket
                Resource: '*'

  {% if component.crawler_s3_path %}
  GlueCrawler:
    Type: AWS::Glue::Crawler
    Properties:
      Name: {{ resource_prefix }}-crawler
      Role: !GetAtt GlueRole.Arn
      DatabaseName: !Ref GlueDatabase
      Targets:
        S3Targets:
          - Path: {{ component.crawler_s3_path }}
      SchemaChangePolicy:
        UpdateBehavior: UPDATE_IN_DATABASE
        DeleteBehavior: LOG
      Tags:
        {% for key, value in tags.items() %}
        {{ key }}: {{ value }}
        {% endfor %}
  {% endif %}

Outputs:
  DatabaseName:
    Description: Glue Database Name
    Value: !Ref GlueDatabase
    Export:
      Name: {{ resource_prefix }}-GlueDB

  GlueRoleArn:
    Description: Glue Role ARN
    Value: !GetAtt GlueRole.Arn
    Export:
      Name: {{ resource_prefix }}-GlueRoleArn
