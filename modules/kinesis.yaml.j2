# ============================================================
# Kinesis Data Stream Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  KinesisStream:
    Type: AWS::Kinesis::Stream
    Properties:
      Name: {{ resource_prefix }}-stream
      RetentionPeriodHours: {{ component.retention_hours }}
      StreamModeDetails:
        StreamMode: {{ component.stream_mode }}
      {% if component.stream_mode == 'PROVISIONED' %}
      ShardCount: {{ component.shard_count }}
      {% endif %}
      StreamEncryption:
        EncryptionType: KMS
        KeyId: alias/aws/kinesis
      Tags:
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

Outputs:
  StreamArn:
    Description: Kinesis Stream ARN
    Value: !GetAtt KinesisStream.Arn
    Export:
      Name: {{ resource_prefix }}-StreamArn

  StreamName:
    Description: Kinesis Stream Name
    Value: !Ref KinesisStream
    Export:
      Name: {{ resource_prefix }}-StreamName
