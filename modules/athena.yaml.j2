# ============================================================
# Athena Workgroup Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  AthenaWorkgroup:
    Type: AWS::Athena::WorkGroup
    Properties:
      Name: {{ component.workgroup_name }}
      Description: Athena workgroup for {{ resource_prefix }}
      State: ENABLED
      WorkGroupConfiguration:
        ResultConfiguration:
          OutputLocation: {{ component.output_location }}
          EncryptionConfiguration:
            EncryptionOption: SSE_S3
        EnforceWorkGroupConfiguration: true
        PublishCloudWatchMetricsEnabled: true
        BytesScannedCutoffPerQuery: 10737418240
      Tags:
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

Outputs:
  WorkgroupName:
    Description: Athena Workgroup Name
    Value: !Ref AthenaWorkgroup
    Export:
      Name: {{ resource_prefix }}-AthenaWorkgroup
