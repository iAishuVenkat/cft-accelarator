# ============================================================
# Secrets Manager Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  Secret:
    Type: AWS::SecretsManager::Secret
    Properties:
      Name: {{ component.secret_name }}
      Description: Managed secret for {{ resource_prefix }}
      {% if component.generate_password %}
      GenerateSecretString:
        SecretStringTemplate: '{}'
        GenerateStringKey: password
        PasswordLength: {{ component.password_length }}
        ExcludeCharacters: '"@/\'
      {% endif %}
      Tags:
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

Outputs:
  SecretArn:
    Description: Secret ARN
    Value: !Ref Secret
    Export:
      Name: {{ resource_prefix }}-SecretArn

  SecretName:
    Description: Secret Name
    Value: {{ component.secret_name }}
    Export:
      Name: {{ resource_prefix }}-SecretName
