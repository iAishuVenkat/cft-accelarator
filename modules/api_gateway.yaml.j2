# ============================================================
# API Gateway Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  # ----- REST API -----
  RestApi:
    Type: AWS::ApiGateway::RestApi
    Properties:
      Name: {{ resource_prefix }}-api
      Description: {{ component.description }}
      EndpointConfiguration:
        Types:
          - REGIONAL
      Tags:
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

  # ----- API Deployment -----
  ApiDeployment:
    Type: AWS::ApiGateway::Deployment
    Properties:
      RestApiId: !Ref RestApi
      Description: Deployment for {{ environment }}

  # ----- API Stage -----
  ApiStage:
    Type: AWS::ApiGateway::Stage
    Properties:
      StageName: {{ component.stage_name }}
      RestApiId: !Ref RestApi
      DeploymentId: !Ref ApiDeployment
      MethodSettings:
        - ResourcePath: '/*'
          HttpMethod: '*'
          MetricsEnabled: true
          DataTraceEnabled: false
          ThrottlingBurstLimit: 500
          ThrottlingRateLimit: 1000
      Tags:
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

  # ----- API Gateway Account (for CloudWatch logging) -----
  ApiGatewayAccount:
    Type: AWS::ApiGateway::Account
    Properties:
      CloudWatchRoleArn: !GetAtt ApiGatewayCloudWatchRole.Arn

  ApiGatewayCloudWatchRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName: {{ resource_prefix }}-apigw-cw-role
      AssumeRolePolicyDocument:
        Version: '2012-10-17'
        Statement:
          - Effect: Allow
            Principal:
              Service: apigateway.amazonaws.com
            Action: sts:AssumeRole
      ManagedPolicyArns:
        - arn:aws:iam::aws:policy/service-role/AmazonAPIGatewayPushToCloudWatchLogs

  # ----- Usage Plan (throttling) -----
  UsagePlan:
    Type: AWS::ApiGateway::UsagePlan
    DependsOn: ApiStage
    Properties:
      UsagePlanName: {{ resource_prefix }}-usage-plan
      ApiStages:
        - ApiId: !Ref RestApi
          Stage: {{ component.stage_name }}
      Throttle:
        BurstLimit: 500
        RateLimit: 1000

Outputs:
  ApiId:
    Description: API Gateway REST API ID
    Value: !Ref RestApi
    Export:
      Name: {{ resource_prefix }}-ApiId

  ApiEndpoint:
    Description: API Gateway Invoke URL
    Value: !Sub 'https://${RestApi}.execute-api.${AWS::Region}.amazonaws.com/{{ component.stage_name }}'
    Export:
      Name: {{ resource_prefix }}-ApiEndpoint
