# ============================================================
# S3 General Purpose Bucket Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  Bucket:
    Type: AWS::S3::Bucket
    Properties:
      BucketName: {{ resource_prefix }}-{{ component.bucket_suffix }}
      BucketEncryption:
        ServerSideEncryptionConfiguration:
          - ServerSideEncryptionByDefault:
              SSEAlgorithm: AES256
      {% if component.versioning %}
      VersioningConfiguration:
        Status: Enabled
      {% endif %}
      PublicAccessBlockConfiguration:
        BlockPublicAcls: {{ component.block_public_access | lower }}
        BlockPublicPolicy: {{ component.block_public_access | lower }}
        IgnorePublicAcls: {{ component.block_public_access | lower }}
        RestrictPublicBuckets: {{ component.block_public_access | lower }}
      {% if component.lifecycle_expiration_days > 0 %}
      LifecycleConfiguration:
        Rules:
          - Id: ExpireObjects
            Status: Enabled
            ExpirationInDays: {{ component.lifecycle_expiration_days }}
      {% endif %}
      Tags:
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

Outputs:
  BucketName:
    Description: S3 Bucket Name
    Value: !Ref Bucket
    Export:
      Name: {{ resource_prefix }}-BucketName

  BucketArn:
    Description: S3 Bucket ARN
    Value: !GetAtt Bucket.Arn
    Export:
      Name: {{ resource_prefix }}-BucketArn
