# ============================================================
# AppSync GraphQL API Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  GraphQLApi:
    Type: AWS::AppSync::GraphQLApi
    Properties:
      Name: {{ component.api_name }}
      AuthenticationType: {{ component.authentication_type }}
      {% if component.authentication_type == 'API_KEY' %}
      AdditionalAuthenticationProviders: []
      {% endif %}
      LogConfig:
        CloudWatchLogsRoleArn: !GetAtt AppSyncLoggingRole.Arn
        FieldLogLevel: ERROR
      XrayEnabled: true
      Tags:
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

  {% if component.authentication_type == 'API_KEY' %}
  GraphQLApiKey:
    Type: AWS::AppSync::ApiKey
    Properties:
      ApiId: !GetAtt GraphQLApi.ApiId
      Description: API Key for {{ resource_prefix }}
  {% endif %}

  AppSyncLoggingRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName: {{ resource_prefix }}-appsync-logs-role
      AssumeRolePolicyDocument:
        Version: '2012-10-17'
        Statement:
          - Effect: Allow
            Principal:
              Service: appsync.amazonaws.com
            Action: sts:AssumeRole
      ManagedPolicyArns:
        - arn:aws:iam::aws:policy/service-role/AWSAppSyncPushToCloudWatchLogs

  GraphQLSchema:
    Type: AWS::AppSync::GraphQLSchema
    Properties:
      ApiId: !GetAtt GraphQLApi.ApiId
      Definition: |
        type Query {
          hello: String
        }
        schema {
          query: Query
        }

Outputs:
  GraphQLUrl:
    Description: GraphQL API URL
    Value: !GetAtt GraphQLApi.GraphQLUrl
    Export:
      Name: {{ resource_prefix }}-GraphQLUrl

  ApiId:
    Description: AppSync API ID
    Value: !GetAtt GraphQLApi.ApiId
    Export:
      Name: {{ resource_prefix }}-ApiId
