# ============================================================
# Application Load Balancer Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  # ----- Security Group -----
  ALBSecurityGroup:
    Type: AWS::EC2::SecurityGroup
    Properties:
      GroupDescription: Security group for {{ resource_prefix }} ALB
      VpcId: !ImportValue {{ project }}-{{ environment }}-vpc-VpcId
      SecurityGroupIngress:
        - IpProtocol: tcp
          FromPort: 80
          ToPort: 80
          CidrIp: 0.0.0.0/0
        - IpProtocol: tcp
          FromPort: 443
          ToPort: 443
          CidrIp: 0.0.0.0/0
      Tags:
        - Key: Name
          Value: {{ resource_prefix }}-alb-sg
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

  # ----- Application Load Balancer -----
  LoadBalancer:
    Type: AWS::ElasticLoadBalancingV2::LoadBalancer
    Properties:
      Name: {{ resource_prefix }}-alb
      Scheme: {% if component.internal %}internal{% else %}internet-facing{% endif %}
      Type: application
      Subnets: !Split
        - ','
        - {% if component.internal %}!ImportValue {{ project }}-{{ environment }}-vpc-PrivateSubnets{% else %}!ImportValue {{ project }}-{{ environment }}-vpc-PublicSubnets{% endif %}
      SecurityGroups:
        - !Ref ALBSecurityGroup
      LoadBalancerAttributes:
        - Key: idle_timeout.timeout_seconds
          Value: '60'
        - Key: routing.http.drop_invalid_header_fields.enabled
          Value: 'true'
      Tags:
        - Key: Name
          Value: {{ resource_prefix }}-alb
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

  # ----- Default Target Group -----
  DefaultTargetGroup:
    Type: AWS::ElasticLoadBalancingV2::TargetGroup
    Properties:
      Name: {{ resource_prefix }}-default-tg
      Port: 80
      Protocol: HTTP
      TargetType: ip
      VpcId: !ImportValue {{ project }}-{{ environment }}-vpc-VpcId
      HealthCheckPath: /health
      HealthCheckIntervalSeconds: 30
      HealthyThresholdCount: 3
      UnhealthyThresholdCount: 3

  # ----- HTTP Listener -----
  HTTPListener:
    Type: AWS::ElasticLoadBalancingV2::Listener
    Properties:
      LoadBalancerArn: !Ref LoadBalancer
      Port: 80
      Protocol: HTTP
      DefaultActions:
        {% if component.ssl_certificate_arn %}
        - Type: redirect
          RedirectConfig:
            Protocol: HTTPS
            Port: '443'
            StatusCode: HTTP_301
        {% else %}
        - Type: forward
          TargetGroupArn: !Ref DefaultTargetGroup
        {% endif %}

  {% if component.ssl_certificate_arn %}
  # ----- HTTPS Listener -----
  HTTPSListener:
    Type: AWS::ElasticLoadBalancingV2::Listener
    Properties:
      LoadBalancerArn: !Ref LoadBalancer
      Port: 443
      Protocol: HTTPS
      Certificates:
        - CertificateArn: {{ component.ssl_certificate_arn }}
      SslPolicy: ELBSecurityPolicy-TLS13-1-2-2021-06
      DefaultActions:
        - Type: forward
          TargetGroupArn: !Ref DefaultTargetGroup
  {% endif %}

Outputs:
  LoadBalancerArn:
    Description: ALB ARN
    Value: !Ref LoadBalancer
    Export:
      Name: {{ resource_prefix }}-ALBArn

  LoadBalancerDNS:
    Description: ALB DNS Name
    Value: !GetAtt LoadBalancer.DNSName
    Export:
      Name: {{ resource_prefix }}-ALBDns

  DefaultTargetGroupArn:
    Description: Default Target Group ARN
    Value: !Ref DefaultTargetGroup
    Export:
      Name: {{ resource_prefix }}-DefaultTGArn
