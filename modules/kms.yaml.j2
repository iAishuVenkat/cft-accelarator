# ============================================================
# KMS Key Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  KMSKey:
    Type: AWS::KMS::Key
    Properties:
      Description: Customer managed key for {{ resource_prefix }}
      EnableKeyRotation: {{ component.enable_rotation | lower }}
      PendingWindowInDays: {{ component.pending_deletion_days }}
      KeyPolicy:
        Version: '2012-10-17'
        Statement:
          - Sid: EnableRootAccountAccess
            Effect: Allow
            Principal:
              AWS: !Sub 'arn:aws:iam::${AWS::AccountId}:root'
            Action: 'kms:*'
            Resource: '*'
          - Sid: AllowKeyAdministration
            Effect: Allow
            Principal:
              AWS: !Sub 'arn:aws:iam::${AWS::AccountId}:root'
            Action:
              - kms:Create*
              - kms:Describe*
              - kms:Enable*
              - kms:List*
              - kms:Put*
              - kms:Update*
              - kms:Revoke*
              - kms:Disable*
              - kms:Get*
              - kms:Delete*
              - kms:TagResource
              - kms:UntagResource
              - kms:ScheduleKeyDeletion
              - kms:CancelKeyDeletion
            Resource: '*'
      Tags:
        - Key: Name
          Value: {{ resource_prefix }}
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

  KMSAlias:
    Type: AWS::KMS::Alias
    Properties:
      AliasName: alias/{{ component.alias }}
      TargetKeyId: !Ref KMSKey

Outputs:
  KeyId:
    Description: KMS Key ID
    Value: !Ref KMSKey
    Export:
      Name: {{ resource_prefix }}-KeyId

  KeyArn:
    Description: KMS Key ARN
    Value: !GetAtt KMSKey.Arn
    Export:
      Name: {{ resource_prefix }}-KeyArn
