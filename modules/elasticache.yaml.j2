# ============================================================
# ElastiCache Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  CacheSubnetGroup:
    Type: AWS::ElastiCache::SubnetGroup
    Properties:
      Description: Subnet group for {{ resource_prefix }}
      SubnetIds: !Split
        - ','
        - !ImportValue {{ project }}-{{ environment }}-vpc-PrivateSubnets

  CacheSecurityGroup:
    Type: AWS::EC2::SecurityGroup
    Properties:
      GroupDescription: Security group for {{ resource_prefix }} cache
      VpcId: !ImportValue {{ project }}-{{ environment }}-vpc-VpcId
      SecurityGroupIngress:
        - IpProtocol: tcp
          FromPort: {% if component.engine == 'redis' %}6379{% else %}11211{% endif %}
          ToPort: {% if component.engine == 'redis' %}6379{% else %}11211{% endif %}
          CidrIp: 10.0.0.0/16
      Tags:
        - Key: Name
          Value: {{ resource_prefix }}-cache-sg

  CacheCluster:
    Type: AWS::ElastiCache::CacheCluster
    Properties:
      ClusterName: {{ resource_prefix }}
      Engine: {{ component.engine }}
      EngineVersion: '{{ component.engine_version }}'
      CacheNodeType: {{ component.node_type }}
      NumCacheNodes: {{ component.num_cache_nodes }}
      CacheSubnetGroupName: !Ref CacheSubnetGroup
      VpcSecurityGroupIds:
        - !Ref CacheSecurityGroup
      Tags:
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

Outputs:
  CacheEndpoint:
    Description: Cache endpoint address
    Value: !GetAtt CacheCluster.RedisEndpoint.Address
    Export:
      Name: {{ resource_prefix }}-CacheEndpoint

  CachePort:
    Description: Cache port
    Value: !GetAtt CacheCluster.RedisEndpoint.Port
    Export:
      Name: {{ resource_prefix }}-CachePort
