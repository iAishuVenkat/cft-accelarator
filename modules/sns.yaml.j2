# ============================================================
# SNS Topic Module - {{ resource_prefix }}
# Generated by CFT Accelerator
# ============================================================

Resources:
  {% if component.kms_encryption %}
  TopicKey:
    Type: AWS::KMS::Key
    Properties:
      Description: Encryption key for {{ resource_prefix }} SNS topic
      EnableKeyRotation: true
      KeyPolicy:
        Version: '2012-10-17'
        Statement:
          - Sid: Allow administration
            Effect: Allow
            Principal:
              AWS: !Sub 'arn:aws:iam::${AWS::AccountId}:root'
            Action: 'kms:*'
            Resource: '*'
          - Sid: Allow SNS
            Effect: Allow
            Principal:
              Service: sns.amazonaws.com
            Action:
              - kms:GenerateDataKey
              - kms:Decrypt
            Resource: '*'

  TopicKeyAlias:
    Type: AWS::KMS::Alias
    Properties:
      AliasName: alias/{{ resource_prefix }}-sns
      TargetKeyId: !Ref TopicKey
  {% endif %}

  Topic:
    Type: AWS::SNS::Topic
    Properties:
      TopicName: {{ resource_prefix }}{% if component.fifo_topic %}.fifo{% endif %}
      {% if component.display_name %}
      DisplayName: {{ component.display_name }}
      {% endif %}
      {% if component.fifo_topic %}
      FifoTopic: true
      ContentBasedDeduplication: true
      {% endif %}
      {% if component.kms_encryption %}
      KmsMasterKeyId: !Ref TopicKey
      {% endif %}
      Tags:
        {% for key, value in tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
        {% endfor %}

Outputs:
  TopicArn:
    Description: SNS Topic ARN
    Value: !Ref Topic
    Export:
      Name: {{ resource_prefix }}-TopicArn
